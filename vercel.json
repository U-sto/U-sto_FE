{
  "routes": [
    {
      "src": "/favicon.ico",
      "dest": "/usto_symbol.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/usto_symbol.svg"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
