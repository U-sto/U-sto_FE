# 1. 모든 파일 및 폴더를 먼저 무시
/*

# 2. react-app 폴더와 그 내부의 src만 허용
!/react-app/
!/react-app/src/
!/react-app/src/**

# 3. 루트에 있는 src 폴더는 절대 무시 (이게 핵심입니다)
/src/

# 4. react-app 실행에 필요한 최소한의 설정들 (필요 없다면 제외 가능)
!/react-app/package.json
!/react-app/index.html
!/react-app/vite.config.ts
!/react-app/tsconfig.json
!/react-app/tsconfig.node.json

# 5. 기타 루트에 있는 모든 지저분한 파일들 무시
.changeset/
.github/
dist/
docs/
node_modules/
.vite/
.env
.nvmrc
.prettierrc
CHANGELOG.md
CONTRIBUTING.md
eslint.config.js
jest.config.js
LICENSE
package.json
pnpm-lock.yaml
README*.md
RELEASES.md
ROADMAP.md
server.json
tsconfig.json
tsup.config.ts
cspell.json
!/.gitignore